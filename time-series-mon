def select_arima_order(series: pd.Series,
                       p_range: range = range(0, 4),
                       d: int = 1,
                       q_range: range = range(0, 4)) -> tuple:

    best_aic = np.inf
    best_order = (1, d, 1)
    results = []

    for p in p_range:
        for q in q_range:
            try:
                model = ARIMA(series, order=(p, d, q))
                fit   = model.fit()
                results.append({'p': p, 'd': d, 'q': q, 'AIC': fit.aic})
                if fit.aic < best_aic:
                    best_aic   = fit.aic
                    best_order = (p, d, q)
            except Exception:
                pass

    results_df = pd.DataFrame(results).sort_values('AIC').head(5)
    print("Top 5 ARIMA orders by AIC:")
    print(results_df.to_string(index=False))
    print(f"\n→ Selected order: ARIMA{best_order} (AIC = {best_aic:.2f})")
    return best_order


