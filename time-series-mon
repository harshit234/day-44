def evaluate_forecast(y_true: pd.Series, y_pred: np.ndarray,
                      model_name: str = 'Model') -> dict:
    
    mae  = mean_absolute_error(y_true, y_pred)
    # Fixed: manual sqrt for RMSE to avoid version-specific 'squared' argument errors
    mse  = mean_squared_error(y_true, y_pred)
    rmse = np.sqrt(mse)
    mape = mean_absolute_percentage_error(y_true, y_pred) * 100

    print(f"\n {model_name} — Forecast Evaluation (hold-out: {len(y_true)} weeks)")
    print(f"  MAE  : {mae:,.2f}  ← average weekly forecast error (same unit as sales)")
    print(f"  RMSE : {rmse:,.2f}  ← penalises large misses more than MAE")
    print(f"  MAPE : {mape:.2f}%  ← percentage error (inventory: target < 15%)")
    return {'model': model_name, 'MAE': mae, 'RMSE': rmse, 'MAPE': mape}



