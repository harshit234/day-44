def audit_sensor_data(df: pd.DataFrame) -> pd.DataFrame:
    numeric_cols = df.select_dtypes(include='number').columns
    rows = []
    for col in numeric_cols:
        s = df[col]
        rows.append({
            'column': col,
            'dtype': str(s.dtype),
            'n_missing': s.isna().sum(),
            'pct_missing': round(s.isna().mean() * 100, 2),
            'n_zeros': (s == 0).sum(),
            'n_negative': (s < 0).sum(),
            'n_inf': np.isinf(s).sum(),
            'n_dupes_consec': (s.diff() == 0).sum(),
            'min': s.min(), 'max': s.max(),
            'std': round(float(s.std()), 4),
            'n_outliers_3iqr': ((s < s.quantile(0.25) - 3*(s.quantile(0.75)-s.quantile(0.25))) |
                                (s > s.quantile(0.75) + 3*(s.quantile(0.75)-s.quantile(0.25)))).sum()
        })
    summary = pd.DataFrame(rows).set_index('column')
    return summary

