ECOMM_PATH = Path("/content/olist_orders_dataset.csv")

def load_ecommerce(path: Path) -> pd.DataFrame:
 
    df = pd.read_csv(path)


    date_col_candidates = [
        'order_purchase_timestamp', 'date', 'ds', 'Date',
        'order_date', 'timestamp', 'week'
    ]
    date_col = next((c for c in date_col_candidates if c in df.columns), None)
    
    if date_col is None:
        date_col = df.select_dtypes(include=['object', 'datetime']).columns[0]
    
    print(f"  Date column identified: '{date_col}'")


    value_col_candidates = ['order_count', 'sales', 'revenue', 'price', 'total_sales']
    value_col = next((c for c in value_col_candidates if c in df.columns), None)
    
    if value_col is None:
        print("  No numeric value column found. Using 'order_id' count as target.")
        df['sales'] = 1
        value_col = 'sales'
    else:
        print(f"  Target column identified: '{value_col}'")
        df = df.rename(columns={value_col: 'sales'})


    df[date_col] = pd.to_datetime(df[date_col])
    df = df[[date_col, 'sales']].rename(columns={date_col: 'date'})
    df = df.set_index('date').sort_index()
    return df

