def clean_ecommerce(df: pd.DataFrame) -> pd.DataFrame:

    df = df.copy()

 
    df = df.resample('D').sum()
    df['sales'] = df['sales'].replace(0, np.nan)   # 0 after resample = missing day

    full_idx = pd.date_range(df.index.min(), df.index.max(), freq='D')
    df = df.reindex(full_idx)
    df['sales'] = df['sales'].interpolate(method='time', limit=7)
    df['sales'] = df['sales'].ffill().bfill()   # handle edges

    p01 = df['sales'].quantile(0.01)
    p99 = df['sales'].quantile(0.99)
    df['sales'] = df['sales'].clip(lower=p01, upper=p99)

    print(f"Clean series: {len(df):,} daily rows  "
          f"| NaN remaining: {df['sales'].isna().sum()}")
    return df

